{
  "name": "june2025playwrightsessions",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test":"npx playwright test",
    "test:dev":"npx playwright test --config=playwright.config.dev.ts",
    "test:qa":"npx playwright test --config=playwright.config.qa.ts",
    "test:stage":"npx playwright test --config=playwright.config.stage.ts",
    "test:prod":"npx playwright test --config=playwright.config.ts",


    "lint": "eslint . --ext .ts,.js --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "lint:report": "eslint . --ext .ts,.js -f html -o eslint-report/index.html || true",
    "lint:report:json": "eslint . --ext .ts,.js -f json -o eslint-report/eslint-results.json || true",

    "allure:generate":"npx allure generate allure-results --clean -o allure-report",
    "allure:open":"npx allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.55.0",
   
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0"
  }
}
